{
  "name": "healthinpulse-backend",
  "version": "1.0.0",
  "description": "API backend do HealthInPulse v7",
  "main": "src/server.js",
  "scripts": {
    "dev":          "nodemon src/server.js",
    "start":        "node src/server.js",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:studio":    "prisma studio",
    "db:seed":      "node src/prisma/seed.js",
    "db:reset":     "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client":       "^5.14.0",
    "bcryptjs":             "^2.4.3",
    "cors":                 "^2.8.5",
    "dotenv":               "^16.4.5",
    "express":              "^4.19.2",
    "express-rate-limit":   "^7.3.1",
    "express-validator":    "^7.1.0",
    "helmet":               "^7.1.0",
    "jsonwebtoken":         "^9.0.2",
    "morgan":               "^1.10.0",
    "multer":               "^1.4.5-lts.1",
    "openai":               "^4.52.1",
    "socket.io":            "^4.7.5",
    "winston":              "^3.13.1"
  },
  "devDependencies": {
    "nodemon":  "^3.1.3",
    "prisma":   "^5.14.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  }
}
