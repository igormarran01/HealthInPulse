generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite não suporta enums, arrays nem Json nativos no Prisma.
// Enums viram String (validados no app); arrays/Json viram String com JSON serializado.

// Enums lógicos (apenas referência):
//   Role:              PATIENT | DOCTOR | ADMIN
//   Gender:            MALE | FEMALE | OTHER
//   ExamStatus:        PENDING | PROCESSING | DONE | ERROR
//   RiskLevel:         LOW | MODERATE | HIGH | CRITICAL
//   TriageStatus:      PENDING | IN_PROGRESS | COMPLETED
//   NotificationType:  ALERT | REMINDER | INFO | CRITICAL
//   DeviceType:        SMARTWATCH | OXIMETER | PRESSURE_MONITOR | ECG | GLUCOMETER | OTHER
//   DeviceStatus:      ACTIVE | INACTIVE | SYNCING | ERROR
//   AppointmentStatus: SCHEDULED | CONFIRMED | CANCELLED | COMPLETED
//   AuditAction:       CREATE | UPDATE | DELETE | LOGIN | LOGOUT | VIEW | EXPORT

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  role          String
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient       Patient?
  doctor        Doctor?
  notifications Notification[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Patient {
  id             String    @id @default(uuid())
  userId         String    @unique
  fullName       String
  dateOfBirth    DateTime
  gender         String
  cpf            String    @unique
  phone          String?
  avatarUrl      String?
  bloodType      String?
  height         Float?
  weight         Float?
  allergies      String    @default("[]")
  chronicConds   String    @default("[]")
  emergencyName  String?
  emergencyPhone String?
  healthCoins    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vitalSigns    VitalSign[]
  exams         Exam[]
  wearableData  WearableData[]
  triageAnswers TriageAnswer[]
  aiReports     AiReport[]
  devices       Device[]
  appointments  Appointment[]
  doctorLinks   DoctorPatient[]
  goals         HealthGoal[]
  coinTxs       HealthCoinTx[]
  redemptions   RewardRedemption[]

  @@index([userId])
}

model Doctor {
  id         String   @id @default(uuid())
  userId     String   @unique
  fullName   String
  crm        String   @unique
  specialty  String
  phone      String?
  avatarUrl  String?
  bio        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  patients     DoctorPatient[]
  appointments Appointment[]
  aiReports    AiReport[]

  @@index([userId])
}

model DoctorPatient {
  id        String   @id @default(uuid())
  doctorId  String
  patientId String
  createdAt DateTime @default(now())

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([doctorId, patientId])
}

model VitalSign {
  id          String   @id @default(uuid())
  patientId   String
  heartRate   Int?
  systolic    Int?
  diastolic   Int?
  oxygenSat   Float?
  temperature Float?
  glucose     Float?
  respirRate  Int?
  weight      Float?
  source      String?
  recordedAt  DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, recordedAt])
}

model Device {
  id         String    @id @default(uuid())
  patientId  String
  name       String
  type       String
  status     String    @default("INACTIVE")
  macAddress String?
  firmware   String?
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())

  patient      Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  wearableData WearableData[]

  @@index([patientId])
}

model WearableData {
  id          String    @id @default(uuid())
  patientId   String
  deviceId    String?
  payload     String
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  device  Device? @relation(fields: [deviceId], references: [id])

  @@index([patientId, createdAt])
}

model Exam {
  id          String    @id @default(uuid())
  patientId   String
  title       String
  description String?
  fileUrl     String
  fileType    String
  status      String    @default("PENDING")
  ocrText     String?
  uploadedAt  DateTime  @default(now())
  processedAt DateTime?

  patient    Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  examResult ExamResult?

  @@index([patientId])
}

model ExamResult {
  id         String   @id @default(uuid())
  examId     String   @unique
  summary    String
  findings   String
  riskLevel  String?
  reviewedBy String?
  createdAt  DateTime @default(now())

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model TriageAnswer {
  id         String    @id @default(uuid())
  patientId  String
  status     String    @default("PENDING")
  answers    String
  riskLevel  String?
  score      Int?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  patient  Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  aiReport AiReport?

  @@index([patientId])
}

model AiReport {
  id          String   @id @default(uuid())
  patientId   String
  doctorId    String?
  triageId    String?  @unique
  type        String
  content     String
  riskLevel   String?
  suggestions String?
  generatedAt DateTime @default(now())

  patient Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor?       @relation(fields: [doctorId], references: [id])
  triage  TriageAnswer? @relation(fields: [triageId], references: [id])

  @@index([patientId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model Appointment {
  id          String   @id @default(uuid())
  patientId   String
  doctorId    String
  scheduledAt DateTime
  duration    Int      @default(30)
  status      String   @default("SCHEDULED")
  notes       String?
  meetUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  String?
  newValue  String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
}

// ─── Gamificação ─────────────────────────────────────────
// Lógico:
//   HealthGoal.metric:    heartRate | systolic | glucose | weight | steps | spo2 | custom
//   HealthGoal.targetCmp: lte | gte | between
//   HealthGoal.status:    ACTIVE | DONE | EXPIRED
//   HealthCoinTx.refType: goal | redemption | bonus | triage
//   Reward.type:          consultation | discount | exam | item
//   RewardRedemption.status: PENDING | APPROVED | DENIED

model HealthGoal {
  id           String    @id @default(uuid())
  patientId    String
  title        String
  description  String?
  metric       String
  targetCmp    String
  targetValue  Float?
  rangeMin     Float?
  rangeMax     Float?
  current      Float?
  progress     Float     @default(0)
  status       String    @default("ACTIVE")
  coinsReward  Int       @default(50)
  source       String?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
}

model HealthCoinTx {
  id        String   @id @default(uuid())
  patientId String
  delta     Int
  reason    String
  refType   String?
  refId     String?
  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model Reward {
  id          String  @id @default(uuid())
  title       String
  description String?
  type        String
  costCoins   Int
  available   Boolean @default(true)
  imageUrl    String?

  redemptions RewardRedemption[]
}

model RewardRedemption {
  id         String   @id @default(uuid())
  patientId  String
  rewardId   String
  costCoins  Int
  status     String   @default("PENDING")
  redeemedAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reward  Reward  @relation(fields: [rewardId], references: [id])

  @@index([patientId, redeemedAt])
}
