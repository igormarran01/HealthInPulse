# ─── Servidor ─────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Banco de dados ───────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:senha@localhost:5432/healthinpulse"

# ─── JWT ──────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=troque_por_secret_forte_aqui
JWT_REFRESH_SECRET=troque_por_outro_secret_forte_aqui
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Frontend ─────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── OpenAI ───────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Logs ─────────────────────────────────────
LOG_LEVEL=info
